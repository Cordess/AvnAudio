{
  "name": "AvnAudioSignalRDemo.Shared",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build AvnAudioSignalRDemo/Shared/AvnAudioSignalRDemo.Shared.csproj",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
